  "keyFeatures": [
    "Authenticate with Epic Games Store (webview, authorization code, or EGL import)",
    "Download and install Epic Games with delta patching and selective downloading",
    "Launch games with online/offline authentication including DRM support",
    "Sync cloud saves bidirectionally with the Epic cloud",
    "Import/export games from/to the Epic Games Launcher",
    "Run Windows games on Linux and macOS via Wine or CrossOver",
    "Manage EOS Overlay installation and updates",
    "Flexible per-game and global configuration via INI config file",
    "Manage game aliases for easier CLI use",
    "Activate titles on third-party launchers (Ubisoft Connect, EA/Origin)"
  ],
